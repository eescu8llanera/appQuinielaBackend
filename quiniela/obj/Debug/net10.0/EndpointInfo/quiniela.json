  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiraEn": {
            "type": "string",
            "format": "date-time"
          },
          "usuario": {
            "$ref": "#/components/schemas/Usuario"
          }
        }
      },
      "Clasificacion": {
        "type": "object",
        "properties": {
          "idClasificacion": {
            "type": "string",
            "format": "uuid"
          },
          "jugadores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JugadorClasificacion"
            }
          }
        }
      },
      "Jornada": {
        "type": "object",
        "properties": {
          "idJornada": {
            "type": "string",
            "format": "uuid"
          },
          "numero": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "nombre": {
            "type": "string"
          },
          "bancaActualizada": {
            "type": "boolean"
          }
        }
      },
      "JugadorClasificacion": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "puntos": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "aciertos": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "banca": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "plenoAcertado": {
            "type": "boolean"
          },
          "aciertosElige8": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "Partidos": {
        "type": "object",
        "properties": {
          "idPartido": {
            "type": "string",
            "format": "uuid"
          },
          "local": {
            "type": "string"
          },
          "visitante": {
            "type": "string"
          },
          "golesLocal": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "golesVisitante": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "idJornada": {
            "type": "string",
            "format": "uuid"
          },
          "orden": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "esPleno": {
            "type": "boolean"
          }
        }
      },
      "Pronostico": {
        "type": "object",
        "properties": {
          "idPronostico": {
            "type": "string",
            "format": "uuid"
          },
          "idPartido": {
            "type": "string",
            "format": "uuid"
          },
          "jugador": {
            "type": "string"
          },
          "golesLocal": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "golesVisitante": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "signo": {
            "type": "string"
          }
        }
      },
      "RegistroRequest": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "rol": {
            "type": "string"
          }
        }
      },
      "Resultado": {
        "type": "object",
        "properties": {
          "idPartido": {
            "type": "string",
            "format": "uuid"
          },
          "golesLocal": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "golesVisitante": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "Usuario": {
        "type": "object",
        "properties": {
          "idUsuario": {
            "type": "string",
            "format": "uuid"
          },
          "nombre": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "rol": {
            "type": "string"
          }
        }
      }
    }
  },
